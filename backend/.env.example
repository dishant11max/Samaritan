# ===========================================================================
# Samaritan — Environment Variable Reference
# Copy this file to .env and fill in ALL values before starting.
# NEVER commit .env to version control.
# ===========================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
PROJECT_NAME=Samaritan
VERSION=1.0.0
ENVIRONMENT=development          # development | staging | production
DEBUG=false
API_V1_STR=/api/v1

# ---------------------------------------------------------------------------
# JWT / Token Security
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
# Use DIFFERENT values for SECRET_KEY and REFRESH_SECRET_KEY.
# ---------------------------------------------------------------------------
SECRET_KEY=CHANGE_ME_generate_a_64_byte_hex_secret
REFRESH_SECRET_KEY=CHANGE_ME_generate_a_different_64_byte_hex_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15
EMAIL_VERIFY_TOKEN_EXPIRE_HOURS=48

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=samaritan
POSTGRES_PASSWORD=CHANGE_ME_strong_database_password
POSTGRES_DB=samaritan
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=CHANGE_ME_if_redis_auth_enabled

# ---------------------------------------------------------------------------
# Celery (defaults to Redis — override only if using a different broker)
# ---------------------------------------------------------------------------
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Rate Limiting & Brute-Force Protection
# ---------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60
LOGIN_RATE_LIMIT_PER_MINUTE=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ---------------------------------------------------------------------------
# Password Policy
# ---------------------------------------------------------------------------
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=true

# ---------------------------------------------------------------------------
# CORS (comma-separated list of allowed origins)
# ---------------------------------------------------------------------------
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ---------------------------------------------------------------------------
# Trusted Hosts (comma-separated — for TrustedHostMiddleware)
# ---------------------------------------------------------------------------
# TRUSTED_HOSTS=localhost,127.0.0.1,your-domain.com

# ---------------------------------------------------------------------------
# Email (SMTP) — set EMAILS_ENABLED=true when SMTP is configured
# ---------------------------------------------------------------------------
EMAILS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@samaritan.io
EMAILS_FROM_NAME=Samaritan Security

# ---------------------------------------------------------------------------
# Initial Admin Seeding (used ONLY on first boot by init_db)
# Change the password immediately after first login.
# ---------------------------------------------------------------------------
ADMIN_EMAIL=admin@samaritan.io
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_Admin@123!

# ---------------------------------------------------------------------------
# File Uploads
# ---------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=10

# ---------------------------------------------------------------------------
# Pagination
# ---------------------------------------------------------------------------
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
